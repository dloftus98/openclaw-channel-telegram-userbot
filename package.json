{
  "name": "openclaw-channel-telegram-userbot",
  "version": "0.4.0",
  "description": "OpenClaw channel plugin — Telegram userbot via MTProto (GramJS)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "auth": "npm run build && node dist/auth.js",
    "build": "tsc -p tsconfig.json",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "prepack": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "keywords": [
    "openclaw",
    "telegram",
    "userbot",
    "mtproto",
    "gramjs",
    "channel",
    "plugin"
  ],
  "license": "MIT",
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/overpod/openclaw-channel-telegram-userbot"
  },
  "author": "overpod",
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "channel": {
      "id": "telegram-userbot",
      "label": "Telegram Userbot",
      "selectionLabel": "Telegram Userbot (MTProto)",
      "detailLabel": "Telegram Userbot",
      "docsPath": "/channels/telegram-userbot",
      "docsLabel": "telegram-userbot",
      "blurb": "Connect a personal Telegram account through MTProto instead of the Bot API.",
      "markdownCapable": true,
      "exposure": {
        "configured": true,
        "setup": false,
        "docs": false
      },
      "showInSetup": false
    },
    "install": {
      "minHostVersion": ">=2026.4.14"
    }
  },
  "dependencies": {
    "node-machine-id": "^1.1.12",
    "telegram": "^2.26.22"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "bun-types": "^1.3.11",
    "openclaw": "^2026.4.14",
    "typescript": "^6.0.2"
  }
}
